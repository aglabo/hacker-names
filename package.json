{
  "name": "@aglabo/project-starter-template",
  "version": "1.0.0",
  "description": "Development environment for project-starter-template",
  "private": true,
  "keywords": [
    "template",
    "starter",
    "oss",
    "development"
  ],
  "author": "atsushifx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/atsushifx/project-starter-template.git"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "devDependencies": {
    "@commitlint/types": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  },
  "scripts": {
    "prepare": "bash ./scripts/setup-dev-env.sh",
    "build": "pnpm exec tsup --config ./configs/tsup.config.ts",
    "clean": "pnpm rimraf dist",
    "scan:secrets": "concurrently \"betterleaks protect --config ./configs/betterleaks.toml\" \"secretlint --secretlintrc ./configs/secretlint.config.yaml .\"",
    "check:sh": "bash templates/runners/run-shfmt.sh --list .",
    "check:types": "tsc --noEmit --incremental",
    "check:dprint": "dprint check",
    "format:dprint": "dprint fmt",
    "format:sh": "bash templates/runners/run-shfmt.sh --format .",
    "lint:spells": "cspell  --config .vscode/cspell.json --cache --cache-location .cache/cspell/cSpellCache ",
    "lint:text": "bash runners/run-textlint.sh ",
    "lint:markdown": "bash runners/run-markdownlint.sh ",
    "lint:gha": "pnpm run lint:gha:actions && pnpm run lint:gha:workflows",
    "lint:gha:actions": "pnpm exec actionlint --config-file ./configs/actionlint.yaml ",
    "lint:gha:workflows": "pnpm exec ghalint --config ./configs/ghalint.yaml run && pnpm exec ghalint --config ./configs/ghalint.yaml run-action",
    "lint": "pnpm exec eslint --config ./configs/eslint.config.js --cache --cache-location .cache/eslint-cache/esLintCache ",
    "lint:types": "pnpm exec eslint --config ./configs/eslint.config.typed.js --cache --cache-location .cache/eslint-cache/esLintCacheTypes",
    "lint:filenames": "pnpm exec ls-lint --config ./configs/ls-lint.yaml ",
    "test:all": "concurrently \"pnpm run test:develop\" \"pnpm run test:functional\" \"pnpm run test:ci\" \"pnpm run test:e2e\" ",
    "test:develop": "pnpm exec vitest run --config ./configs/vitest.config.unit.ts",
    "test:functional": "pnpm exec vitest run --config ./configs/vitest.config.functional.ts",
    "test:ci": "pnpm exec vitest run --config ./configs/vitest.config.integration.ts",
    "test:e2e": "pnpm exec vitest run --config ./configs/vitest.config.e2e.ts",
    "lint:sh": "bash ./runners/run-shellcheck.sh ",
    "test:sh": "bash ./runners/run-shellspec.sh ",
    "test:sh:all": "bash ./runners/run-shellspec.sh all"
  }
}
